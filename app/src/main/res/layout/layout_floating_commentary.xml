<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_floating_panel"
    android:padding="8dp"
    android:elevation="4dp">

    <!-- 🏷️ ミニヘッダー -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_recording_dot"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/tv_commentary_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LIVE COMMENTARY"
            android:textColor="#FF88AA"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="120dp">

        <TextView
            android:id="@+id/tv_floating_commentary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="6dp"
            android:background="@drawable/bg_comment_bubble"
            android:lineSpacingExtra="2dp"/>
    </ScrollView>
</LinearLayout>