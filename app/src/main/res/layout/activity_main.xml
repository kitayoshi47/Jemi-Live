<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#1E1E1E">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jemi-Live 準備室🌸"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FF88AA"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 🔑 API Key -->
        <TextView
            android:id="@+id/tv_api_key_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="▼ Gemini API キー"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <EditText
            android:id="@+id/et_api_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AIzaSy..."
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:inputType="textPassword"
            android:backgroundTint="#FF88AA"
            app:layout_constraintTop_toBottomOf="@id/tv_api_key_label" />

        <!-- 💖 おまじない (システムプロンプト) -->
        <TextView
            android:id="@+id/tv_omajinai_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="▼ おまじない（性格・口調）"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_api_key" />

        <EditText
            android:id="@+id/et_omajinai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="元気に！可愛く！関西弁で！など"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:backgroundTint="#FF88AA"
            app:layout_constraintTop_toBottomOf="@id/tv_omajinai_label" />

        <!-- 📺 表示モード -->
        <TextView
            android:id="@+id/tv_display_mode_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="▼ 画面モードはどうする？"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_omajinai" />

        <RadioGroup
            android:id="@+id/rg_display_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_display_mode_label">
            <RadioButton android:id="@+id/rb_display_dual" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📺 2画面コックピット（Thor推奨）" android:textColor="#FFFFFF" android:textStyle="bold" android:checked="true"/>
            <RadioButton android:id="@+id/rb_display_single" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📱 1画面フローティング" android:textColor="#FFFFFF" android:textStyle="bold"/>
        </RadioGroup>

        <!-- 📐 撮影エリアの設定 -->
        <TextView
            android:id="@+id/tv_capture_area_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="▼ 撮影する範囲はどうする？"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rg_display_mode" />

        <RadioGroup
            android:id="@+id/rg_capture_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_capture_area_label">
            <RadioButton android:id="@+id/rb_area_manual" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⬛️ 手動（緑の枠で合わせる）" android:textColor="#FFFFFF" android:textStyle="bold" android:checked="true"/>
            <RadioButton android:id="@+id/rb_area_4_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🟦 中央 4:3（レトロゲーム向け）" android:textColor="#FFFFFF" android:textStyle="bold"/>
            <RadioButton android:id="@+id/rb_area_16_9" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🟥 全画面 16:9（最新ゲーム向け）" android:textColor="#FFFFFF" android:textStyle="bold"/>
        </RadioGroup>

        <!-- 🛠️ デバッグモード設定 -->
        <CheckBox
            android:id="@+id/cb_debug_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="🛠️ デバッグモード（API通信なし）"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:buttonTint="#FF88AA"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rg_capture_area" />

        <!-- 🚀 開始ボタン -->
        <Button
            android:id="@+id/btn_start_live"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:text="LIVE開始っ！🚀"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FF88AA"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/cb_debug_mode" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>