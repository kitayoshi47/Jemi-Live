<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#AA000000"
    android:padding="4dp"
    android:gravity="center">

    <!-- 🖼️ プレビュー切り替えボタン（デバッグ用） -->
    <Button
        android:id="@+id/btn_floating_toggle_preview"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="🖼️"
        android:textSize="14sp"
        android:backgroundTint="#884444FF"
        android:visibility="gone" />

    <!-- 📸 撮影＆実況ボタン -->
    <Button
        android:id="@+id/btn_floating_capture"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="4dp"
        android:text="📸"
        android:textSize="14sp"
        android:backgroundTint="#88000000" />

    <!-- ❌ サービス終了ボタン -->
    <Button
        android:id="@+id/btn_floating_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="❌"
        android:textSize="14sp"
        android:backgroundTint="#88FF4444" />

</LinearLayout>