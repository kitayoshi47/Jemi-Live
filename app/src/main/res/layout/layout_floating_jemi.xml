<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_floating_panel"
    android:padding="6dp"
    android:gravity="center"
    android:elevation="4dp">

    <!-- 🔧 枠調整モード切り替え -->
    <Button
        android:id="@+id/btn_floating_edit_frame"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="🔧"
        android:textSize="16sp"
        android:background="@drawable/bg_action_button_blue"
        android:stateListAnimator="@null" />

    <Button
        android:id="@+id/btn_floating_capture"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="6dp"
        android:text="📸"
        android:textSize="20sp"
        android:background="@drawable/bg_action_button_dark"
        android:stateListAnimator="@null" />

    <Button
        android:id="@+id/btn_floating_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="❌"
        android:textSize="16sp"
        android:background="@drawable/bg_action_button_red"
        android:stateListAnimator="@null" />
</LinearLayout>