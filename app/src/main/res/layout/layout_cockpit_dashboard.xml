<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ⬆️ 上段：テキストエリアとコントロールパネル -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- 📢 左側：実況テキストエリア（スクロール対応っ！） -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_floating_panel"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_recording_dot"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/tv_cockpit_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JEMI-LIVE COCKPIT"
                        android:textColor="#FF88AA"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fillViewport="true">
                    <TextView
                        android:id="@+id/tv_cockpit_commentary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="4dp"/>
                </ScrollView>
            </LinearLayout>

            <!-- 🎛️ 右側：コントロールパネル -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/iv_cockpit_preview"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="#333333"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter" />

                <!-- ⏱️ 撮影間隔スライダー -->
                <LinearLayout
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_cockpit_interval"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="撮影: 2.0s"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                    <SeekBar
                        android:id="@+id/sb_cockpit_interval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="20"
                        android:progress="10"
                        android:progressTint="#FF88AA"
                        android:thumbTint="#FF88AA" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <Button
                        android:id="@+id/btn_cockpit_capture"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="📸"
                        android:textSize="20sp"
                        android:background="@drawable/bg_action_button_dark"
                        android:stateListAnimator="@null" />
                    <Button
                        android:id="@+id/btn_cockpit_special"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:text="✨"
                        android:textSize="16sp"
                        android:background="@drawable/bg_action_button_blue"
                        android:stateListAnimator="@null" />
                    <Button
                        android:id="@+id/btn_cockpit_edit_frame"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:text="🔧"
                        android:textSize="16sp"
                        android:background="@drawable/bg_action_button_blue"
                        android:stateListAnimator="@null" />
                    <Button
                        android:id="@+id/btn_cockpit_close"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:text="❌"
                        android:textSize="14sp"
                        android:background="@drawable/bg_action_button_red"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ⬇️ 下段：バッファプレビュー -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="12dp"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/ll_buffer_preview"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 🌌 オーバーレイ：ミニウィンドウ（機能一覧） -->
    <LinearLayout
        android:id="@+id/ll_mini_window"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_floating_panel"
        android:padding="16dp"
        android:visibility="gone"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPECIAL ACTIONS"
            android:textColor="#FF88AA"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"/>

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3">
            <Button android:id="@+id/btn_menu_translate" android:layout_width="110dp" android:layout_height="40dp" android:text="🌎 翻訳" android:textSize="12sp" android:layout_margin="4dp" android:background="@drawable/bg_action_button_dark" android:stateListAnimator="@null" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btn_menu_guide" android:layout_width="110dp" android:layout_height="40dp" android:text="💡 攻略" android:textSize="12sp" android:layout_margin="4dp" android:background="@drawable/bg_action_button_dark" android:stateListAnimator="@null" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btn_menu_status" android:layout_width="110dp" android:layout_height="40dp" android:text="📊 情報" android:textSize="12sp" android:layout_margin="4dp" android:background="@drawable/bg_action_button_dark" android:stateListAnimator="@null" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btn_menu_lore" android:layout_width="110dp" android:layout_height="40dp" android:text="📖 解説" android:textSize="12sp" android:layout_margin="4dp" android:background="@drawable/bg_action_button_dark" android:stateListAnimator="@null" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btn_menu_trivia" android:layout_width="110dp" android:layout_height="40dp" android:text="🤫 裏話" android:textSize="12sp" android:layout_margin="4dp" android:background="@drawable/bg_action_button_dark" android:stateListAnimator="@null" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btn_menu_query" android:layout_width="110dp" android:layout_height="40dp" android:text="✏️ 質問" android:textSize="12sp" android:layout_margin="4dp" android:background="@drawable/bg_action_button_blue" android:stateListAnimator="@null" android:textColor="#FFFFFF"/>
        </GridLayout>
    </LinearLayout>

    <!-- ✍️ オーバーレイ：質問入力UI -->
    <LinearLayout
        android:id="@+id/ll_query_input"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_floating_panel"
        android:padding="16dp"
        android:visibility="gone"
        android:elevation="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️ ジェミに質問っ！"
            android:textColor="#FF88AA"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_query_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:hint="右下のアイコンって何？など"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="@android:color/transparent"
            android:padding="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="8dp">
            <Button
                android:id="@+id/btn_query_cancel"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="キャンセル"
                android:textSize="11sp"
                android:background="@android:color/transparent"
                android:textColor="#888888"
                android:stateListAnimator="@null"/>
            <Button
                android:id="@+id/btn_query_send"
                android:layout_width="80dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="送信っ！"
                android:textSize="11sp"
                android:background="@drawable/bg_action_button_blue"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>